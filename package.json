{
  "name": "opencode-byterover",
  "version": "0.1.0",
  "description": "OpenCode ByteRover Plugin",
  "homepage": "https://github.com/ian-pascoe/opencode-byterover#readme",
  "bugs": {
    "url": "https://github.com/ian-pascoe/opencode-byterover/issues"
  },
  "license": "MIT",
  "author": "Ian Pascoe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ian-pascoe/opencode-byterover.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rolldown -c",
    "changeset": "changeset",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "release": "pnpm run build && changeset publish",
    "typecheck": "tsc --noEmit",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "dependencies": {
    "@byterover/brv-bridge": "^1.1.0",
    "@opencode-ai/plugin": "^1.14.22",
    "@opencode-ai/sdk": "^1.14.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "rolldown": "1.0.0-rc.17",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2"
}
